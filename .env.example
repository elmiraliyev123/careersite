# Public site metadata
NEXT_PUBLIC_SITE_URL=https://trystradify.app
NEXT_PUBLIC_ADMIN_SUBDOMAIN=adminlog

# Admin login
ADMIN_LOGIN_USERNAME=admin
ADMIN_LOGIN_PASSWORD=replace-with-a-strong-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Cron/API route protection
CRON_SECRET=replace-with-a-long-random-secret
REVALIDATION_CRON_SECRET=replace-with-a-long-random-secret

# Optional AI enrichment
OPENAI_API_KEY=
OPENAI_RESPONSES_MODEL=

# Optional logging controls
NEXT_PUBLIC_PLATFORM_TIMING=1
NEXT_PUBLIC_DB_TIMING=1
